#!/bin/bash
#
# Git pre-push hook
# Validates branch name before pushing
#
# This hook is called by "git push" and can be used to prevent a push from taking place.
# The hook is called with two parameters which provide the name and location of the
# destination remote, if a named remote is not being used both values will be the same.

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get the current branch name
BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)

# Get the project root directory
PROJECT_ROOT=$(git rev-parse --show-toplevel)

# Check if Python is available
if ! command -v python &> /dev/null && ! command -v python3 &> /dev/null; then
    echo -e "${RED}❌ Error: Python is not installed or not in PATH${NC}"
    echo "Please install Python 3.8+ to use branch name validation"
    exit 1
fi

# Use python3 if available, otherwise python
PYTHON_CMD="python3"
if ! command -v python3 &> /dev/null; then
    PYTHON_CMD="python"
fi

# Validate the branch name
echo -e "${YELLOW}🔍 Validating branch name: $BRANCH_NAME${NC}"

if $PYTHON_CMD "$PROJECT_ROOT/src/main/cli.py" validate-branch "$BRANCH_NAME"; then
    echo -e "${GREEN}✓ Branch name is valid${NC}"
    exit 0
else
    echo -e "${RED}❌ Branch name validation failed${NC}"
    echo ""
    echo "Your push has been blocked because the branch name does not follow"
    echo "the required naming convention."
    echo ""
    echo "To rename your branch:"
    echo "  git branch -m <new-branch-name>"
    echo ""
    echo "To bypass this hook (not recommended):"
    echo "  git push --no-verify"
    exit 1
fi
