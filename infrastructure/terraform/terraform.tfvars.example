# AWS Configuration
aws_region = "ap-south-1"

# EC2 Configuration
instance_type = "t2.micro"

# Environment
environment = "Dev"

# SSH Key Pair Name (must exist in AWS)
# Create one with: aws ec2 create-key-pair --key-name git-workflow-enforcer-key --query 'KeyMaterial' --output text > git-workflow-enforcer-key.pem
key_name = "your-key-pair-name"

# Your IP Address for SSH Access (CIDR notation)
# Find your IP: curl ifconfig.me
# Add /32 for single IP: e.g., "203.0.113.25/32"
my_ip = "YOUR_IP_ADDRESS/32"

# Project Name
project_name = "git-workflow-enforcer"
