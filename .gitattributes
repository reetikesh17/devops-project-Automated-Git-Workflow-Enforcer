# Git Attributes for Automated Git Workflow Enforcer
# Ensures consistent line endings across platforms

# Auto detect text files and normalize line endings to LF
* text=auto

# Explicitly declare text files with LF line endings
*.py text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tf text eol=lf
*.hcl text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf
*.mk text eol=lf

# Windows-specific files with CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf
.gitmodules text eol=lf

# Docker files
*.dockerignore text eol=lf

# CI/CD files
.gitlab-ci.yml text eol=lf
.travis.yml text eol=lf
azure-pipelines.yml text eol=lf

# Kubernetes files
*.yaml text eol=lf
*.yml text eol=lf

# Terraform files
*.tf text eol=lf
*.tfvars text eol=lf
*.hcl text eol=lf

# Shell scripts must have LF (critical for Linux/Mac execution)
*.sh text eol=lf

# Python files must have LF
*.py text eol=lf

# Ensure scripts are executable on Unix systems
*.sh filter=lfs diff=lfs merge=lfs -text
